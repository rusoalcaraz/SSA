# -------------------------------------------------------
# Backend — variables de entorno requeridas
# Copia este archivo como .env y rellena los valores
# -------------------------------------------------------

# --- Servidor ---
PORT=4000
NODE_ENV=development

# --- Base de datos ---
MONGODB_URI=mongodb://localhost:27017/ssa

# --- JWT (genera valores aleatorios largos en produccion) ---
JWT_SECRET=cambia_esto_por_un_secreto_muy_largo_y_aleatorio
JWT_REFRESH_SECRET=cambia_esto_por_otro_secreto_diferente_al_anterior

# --- CORS ---
# URL del frontend. En produccion usar el dominio real.
FRONTEND_URL=http://localhost:3000

# --- Notificaciones por correo (opcional) ---
# Si no se configuran, las notificaciones se deshabilitan silenciosamente.
SMTP_HOST=smtp.ejemplo.com
SMTP_PORT=587
SMTP_USER=notificaciones@ejemplo.com
SMTP_PASS=contrasena_smtp
SMTP_FROM="SSA Sistema <notificaciones@ejemplo.com>"
